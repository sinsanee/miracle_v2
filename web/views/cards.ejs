    <!-- Bulk Confirmation Modal -->
    <div id="bulk-confirm-modal" class="modal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal('bulk-confirm-modal')">&times;</button>
            <h3 class="modal-header">Confirm Bulk Creation</h3>
            
            <div style="text-align: center; padding: 40px;">
                <div style="font-size: 4rem; color: var(--accent); font-weight: 900; font-family: 'Orbitron', sans-serif;">
                    <span id="bulk-confirm-count">0</span>
                </div>
                <p style="font-size: 1.5rem; color: rgba(255,255,255,0.8); margin-top: 10px;">
                    Cards will be created
                </p>
            </div>
            
            <p style="text-align: center; margin: 20px 0; color: rgba(255,255,255,0.8);">
                Are you sure you want to add these cards?
            </p>
            
            <div class="form-actions">
                <button type="button" class="btn" onclick="closeModal('bulk-confirm-modal')">Cancel</button>
                <button type="button" class="btn btn-warning" onclick="editFromBulkConfirmation()">Edit</button>
                <button type="button" class="btn btn-primary" onclick="confirmBulkAdd()">Add All Cards</button>
            </div>
        </div>
    </div>

    <script>
        // Global variables
        var isEditMode = false;
        var editionsData = JSON.stringify(cards.reduce((acc, card) => {
            if (!acc[card.name] || acc[card.name] < card.edition) {
                acc[card.name] = card.edition;
            }
            return acc;
        }, {}))

        // Message function
        function showMessage(text, isError) {
            isError = isError || false;
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = text;
            messageDiv.classList.remove('error');
            if (isError) {
                messageDiv.classList.add('error');
            }
            messageDiv.classList.add('show');
            
            setTimeout(function() {
                messageDiv.classList.remove('show');
            }, 4000);
        }

        // Toggle functions - defined early
        function toggleSetInputs() {
            const isNew = document.getElementById('set-new').checked;
            document.getElementById('set-select').style.display = isNew ? 'none' : 'block';
            document.getElementById('set-name-input').style.display = isNew ? 'block' : 'none';
            
            if (isNew) {
                document.getElementById('set-select').removeAttribute('required');
                document.getElementById('set-name-input').setAttribute('required', 'required');
            } else {
                document.getElementById('set-select').setAttribute('required', 'required');
                document.getElementById('set-name-input').removeAttribute('required');
            }
        }

        function toggleBulkSet() {
            const isNew = document.getElementById('bulk-set-new').checked;
            document.getElementById('bulk-set-select').style.display = isNew ? 'none' : 'block';
            document.getElementById('bulk-set-name-input').style.display = isNew ? 'block' : 'none';
        }

        function toggleEditionInputs() {
            const isNew = document.getElementById('edition-new').checked;
            document.getElementById('edition-select').disabled = isNew;
        }

        function toggleSchedule() {
            const notDropping = document.getElementById('dropping-no').checked;
            const scheduleGroup = document.getElementById('scheduled-drop-group');
            
            if (notDropping) {
                scheduleGroup.classList.add('show');
            } else {
                scheduleGroup.classList.remove('show');
                document.getElementById('scheduled-drop').value = '';
            }
        }

        // Image handling and preview functions
        function handleImageChange() {
            updatePreview();
        }

        function updatePreview() {
            var cardName = document.getElementById('card-name').value || 'Card Name';
            var edition = document.getElementById('edition-select').value || '1';
            var setSelect = document.getElementById('set-select');
            var setId = setSelect.value;
            var setName;
            
            // Check if creating new set
            if (document.getElementById('set-new') && document.getElementById('set-new').checked) {
                setName = document.getElementById('set-name-input').value || 'New Set';
            } else {
                setName = setSelect.options[setSelect.selectedIndex]?.text || 'Set Name';
            }
            
            var cropMode = document.getElementById('crop-mode').value;
            var imageFile = document.getElementById('card-image').files[0];
            var imageUrl = document.getElementById('image-url').value;

            if (!imageFile && !imageUrl) {
                document.getElementById('preview-container').style.display = 'none';
                return;
            }

            document.getElementById('preview-container').style.display = 'block';
            document.getElementById('preview-loading').style.display = 'block';
            document.getElementById('preview-image').style.display = 'none';

            var formData = new FormData();
            if (imageFile) {
                formData.append('image', imageFile);
            } else {
                formData.append('imageUrl', imageUrl);
            }
            formData.append('name', cardName);
            formData.append('subtitle', 'Edition ' + edition);
            formData.append('footer', setName);
            formData.append('cropMode', cropMode);
            formData.append('setId', setId);

            fetch('/admin/cards/preview', {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    var previewImg = document.getElementById('preview-image');
                    previewImg.src = data.preview;
                    previewImg.style.display = 'block';
                } else {
                    showMessage('Failed to generate preview: ' + (data.error || 'Unknown error'), true);
                }
                document.getElementById('preview-loading').style.display = 'none';
            })
            .catch(function(error) {
                document.getElementById('preview-loading').style.display = 'none';
                showMessage('Preview generation error', true);
            });
        }

        // UPDATED BULK UPLOAD FUNCTIONS WITH PREVIEW AND PER-CARD CROP

        var bulkCardCount = 0;
        var bulkPreviewData = null;

        function openBulkModal() {
            bulkCardCount = 0;
            document.getElementById('bulk-cards-container').innerHTML = '';
            addBulkCardRow();
            addBulkCardRow();
            addBulkCardRow();
            document.getElementById('bulk-modal').classList.add('show');
        }

        function addBulkCardRow() {
            bulkCardCount++;
            var container = document.getElementById('bulk-cards-container');
            var row = document.createElement('div');
            row.className = 'bulk-card-item';
            row.id = 'bulk-card-' + bulkCardCount;
            row.innerHTML = `
                <div class="bulk-card-header">
                    <strong>Card ${bulkCardCount}</strong>
                    <button type="button" class="btn btn-small btn-danger" onclick="removeBulkCard(${bulkCardCount})">Remove</button>
                </div>
                <input type="text" placeholder="Card Name" name="bulk-name-${bulkCardCount}" required style="width: 100%; margin-bottom: 10px;">
                <input type="number" placeholder="Edition" name="bulk-edition-${bulkCardCount}" value="1" min="1" required style="width: 100%; margin-bottom: 10px;">
                <div style="margin-bottom: 10px;">
                    <label style="display: block; margin-bottom: 5px; font-size: 0.9rem;">Crop Mode</label>
                    <select name="bulk-crop-${bulkCardCount}" style="width: 100%;">
                        <option value="centre">Center (Default)</option>
                        <option value="top">Top</option>
                        <option value="bottom">Bottom</option>
                        <option value="left">Left</option>
                        <option value="right">Right</option>
                        <option value="stretch">Stretch</option>
                    </select>
                </div>
                <input type="file" accept="image/*" name="bulk-image-${bulkCardCount}" style="width: 100%; margin-bottom: 10px;">
                <input type="text" placeholder="Or paste image URL" name="bulk-url-${bulkCardCount}" style="width: 100%;">
            `;
            container.appendChild(row);
        }

        function removeBulkCard(id) {
            var element = document.getElementById('bulk-card-' + id);
            if (element) {
                element.remove();
            }
        }

        function toggleBulkSet() {
            const isNew = document.getElementById('bulk-set-new').checked;
            document.getElementById('bulk-set-select').style.display = isNew ? 'none' : 'block';
            document.getElementById('bulk-set-name-input').style.display = isNew ? 'block' : 'none';
        }

        async function generateBulkPreviews() {
            // Collect card data
            var cardElements = document.querySelectorAll('.bulk-card-item');
            var cards = [];
            var previewPromises = [];
            
            // Get set info for preview
            var setName = '';
            var setId = null;
            if (document.getElementById('bulk-set-existing').checked) {
                var setSelect = document.getElementById('bulk-set-select');
                setId = setSelect.value;
                setName = setSelect.options[setSelect.selectedIndex]?.text || 'Set Name';
            } else {
                setName = document.getElementById('bulk-set-name-input').value || 'New Set';
            }
            
            for (var i = 0; i < cardElements.length; i++) {
                var element = cardElements[i];
                var nameInput = element.querySelector('[name^="bulk-name-"]');
                var editionInput = element.querySelector('[name^="bulk-edition-"]');
                var cropInput = element.querySelector('[name^="bulk-crop-"]');
                var imageInput = element.querySelector('[name^="bulk-image-"]');
                var urlInput = element.querySelector('[name^="bulk-url-"]');
                
                if (!nameInput || !editionInput) continue;
                
                var hasImage = imageInput && imageInput.files[0];
                var hasUrl = urlInput && urlInput.value.trim();
                
                if (hasImage || hasUrl) {
                    var cardData = {
                        name: nameInput.value,
                        edition: parseInt(editionInput.value),
                        cropMode: cropInput.value,
                        index: i
                    };
                    
                    // Create preview request
                    var formData = new FormData();
                    if (hasImage) {
                        formData.append('image', imageInput.files[0]);
                    } else {
                        formData.append('imageUrl', urlInput.value.trim());
                    }
                    formData.append('name', cardData.name);
                    formData.append('subtitle', 'Edition ' + cardData.edition);
                    formData.append('footer', setName);
                    formData.append('cropMode', cardData.cropMode);
                    if (setId) {
                        formData.append('setId', setId);
                    }
                    
                    cards.push(cardData);
                    previewPromises.push(
                        fetch('/admin/cards/preview', {
                            method: 'POST',
                            body: formData
                        })
                        .then(function(response) { return response.json(); })
                        .then(function(data) {
                            return { success: data.success, preview: data.preview, error: data.error };
                        })
                        .catch(function(error) {
                            return { success: false, error: error.message };
                        })
                    );
                }
            }
            
            if (cards.length === 0) {
                showMessage('Please add at least one card with an image or URL', true);
                return;
            }
            
            // Show loading message
            showMessage('Generating ' + cards.length + ' previews...');
            
            // Wait for all previews
            Promise.all(previewPromises).then(function(results) {
                displayBulkPreviews(cards, results);
            });
        }

        function displayBulkPreviews(cards, previews) {
            var container = document.getElementById('bulk-preview-container');
            container.innerHTML = '';
            
            for (var i = 0; i < cards.length; i++) {
                var card = cards[i];
                var preview = previews[i];
                
                var previewCard = document.createElement('div');
                previewCard.style.cssText = 'background: rgba(0,0,0,0.3); padding: 15px; border-radius: 10px; text-align: center;';
                
                if (preview.success) {
                    previewCard.innerHTML = `
                        <img src="${preview.preview}" style="width: 100%; border-radius: 8px; margin-bottom: 10px;">
                        <strong style="display: block; color: var(--accent);">${card.name}</strong>
                        <small style="color: rgba(255,255,255,0.7);">Edition ${card.edition} - ${card.cropMode}</small>
                    `;
                } else {
                    previewCard.innerHTML = `
                        <div style="padding: 40px; color: var(--primary);">
                            <strong>${card.name}</strong><br>
                            <small>Preview failed: ${preview.error || 'Unknown error'}</small>
                        </div>
                    `;
                }
                
                container.appendChild(previewCard);
            }
            
            document.getElementById('bulk-preview-modal').classList.add('show');
        }

        function confirmBulkFromPreview() {
            closeModal('bulk-preview-modal');
            // Trigger the normal bulk submit
            document.getElementById('bulk-form').dispatchEvent(new Event('submit', { cancelable: true }));
        }

        function handleBulkSubmit(event) {
            event.preventDefault();
            
            var formData = new FormData();
            var cards = [];
            
            // Get set info
            var setId = document.getElementById('bulk-set-existing').checked ? 
                document.getElementById('bulk-set-select').value : null;
            var setName = document.getElementById('bulk-set-new').checked ? 
                document.getElementById('bulk-set-name-input').value : null;
            var dropping = document.querySelector('input[name="bulk-dropping"]:checked').value;
            
            formData.append('set_id', setId || '');
            formData.append('set_name', setName || '');
            formData.append('dropping', dropping);
            
            // Collect all cards with their individual crop modes
            var cardElements = document.querySelectorAll('.bulk-card-item');
            var imageUrls = [];
            var cropModes = [];
            
            cardElements.forEach(function(element, index) {
                var nameInput = element.querySelector('[name^="bulk-name-"]');
                var editionInput = element.querySelector('[name^="bulk-edition-"]');
                var cropInput = element.querySelector('[name^="bulk-crop-"]');
                var imageInput = element.querySelector('[name^="bulk-image-"]');
                var urlInput = element.querySelector('[name^="bulk-url-"]');
                
                if (nameInput && editionInput) {
                    var hasImage = imageInput && imageInput.files[0];
                    var hasUrl = urlInput && urlInput.value.trim();
                    
                    if (hasImage || hasUrl) {
                        cards.push({
                            name: nameInput.value,
                            edition: parseInt(editionInput.value)
                        });
                        
                        // Store crop mode for this card
                        cropModes.push(cropInput.value);
                        
                        if (hasImage) {
                            formData.append('images', imageInput.files[0]);
                            imageUrls.push('');
                        } else {
                            formData.append('images', new File([], ''));
                            imageUrls.push(urlInput.value.trim());
                        }
                    }
                }
            });
            
            if (cards.length === 0) {
                showMessage('Please add at least one card with an image or URL', true);
                return;
            }
            
            formData.append('cardsData', JSON.stringify(cards));
            formData.append('imageUrls', JSON.stringify(imageUrls));
            formData.append('cropModes', JSON.stringify(cropModes));
            
            // Show confirmation modal
            showBulkConfirmation(cards.length, formData);
        }

        // Confirmation modal functions
        var pendingCardData = null;
        var pendingBulkData = null;

        function showBulkConfirmation(count, formData) {
            pendingBulkData = formData;
            document.getElementById('bulk-confirm-count').textContent = count;
            document.getElementById('bulk-confirm-modal').classList.add('show');
        }

        function editFromBulkConfirmation() {
            closeModal('bulk-confirm-modal');
            // Bulk modal is still open, user can edit
        }

        function confirmBulkAdd() {
            if (!pendingBulkData) return;
            
            showMessage('Creating cards...');
            closeModal('bulk-confirm-modal');
            
            fetch('/admin/cards/bulk-create', {
                method: 'POST',
                body: pendingBulkData
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    closeModal('bulk-modal');
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    showMessage(result.error || 'Bulk creation failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred during bulk creation', true);
            });
        }


        function showCardConfirmation(previewSrc, formData) {
            pendingCardData = formData;
            document.getElementById('confirm-preview-image').src = previewSrc;
            document.getElementById('confirm-modal').classList.add('show');
        }

        function editFromConfirmation() {
            closeModal('confirm-modal');
            // Card modal is still open, user can edit
        }

        function confirmAddCard() {
            if (!pendingCardData) return;
            
            showMessage('Creating card...');
            closeModal('confirm-modal');
            
            var url = isEditMode ? '/admin/cards/' + pendingCardData.get('card_id') + '/update' : '/admin/cards/create-with-image';
            
            fetch(url, {
                method: 'POST',
                body: pendingCardData
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    closeModal('card-modal');
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Operation failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred. Please try again.', true);
            });
        }

        // Modal functions
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('show');
        }

        function openCreateModal() {
            isEditMode = false;
            document.getElementById('modal-title').textContent = 'Add New Card';
            document.getElementById('card-form').reset();
            document.getElementById('card-id').value = '';
            document.getElementById('card-modal').classList.add('show');
            toggleSetInputs();
            toggleEditionInputs();
            toggleSchedule();
        }

        function openEditModal(cardId) {
            isEditMode = true;
            document.getElementById('modal-title').textContent = 'Edit Card';
            
            fetch('/admin/cards/' + cardId)
                .then(function(response) { return response.json(); })
                .then(function(card) {
                    document.getElementById('card-id').value = card.id;
                    document.getElementById('card-name').value = card.name;
                    document.getElementById('edition-select').value = card.edition;
                    document.getElementById('set-select').value = card.set_id;
                    document.getElementById('image-url').value = card.image || '';
                    
                    if (card.dropping === 1) {
                        document.getElementById('dropping-yes').checked = true;
                    } else {
                        document.getElementById('dropping-no').checked = true;
                    }
                    
                    if (card.scheduled_drop) {
                        var date = new Date(card.scheduled_drop);
                        var localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
                        document.getElementById('scheduled-drop').value = localDate.toISOString().slice(0, 16);
                    }
                    
                    toggleSchedule();
                    document.getElementById('card-modal').classList.add('show');
                })
                .catch(function(error) {
                    showMessage('Failed to load card data', true);
                });
        }

        function openStatsModal(cardId, dropped, grabbed) {
            document.getElementById('stats-card-id').value = cardId;
            document.getElementById('dropped-count').value = dropped;
            document.getElementById('grabbed-count').value = grabbed;
            document.getElementById('stats-modal').classList.add('show');
        }

        // Toggle functions
        window.toggleSetInputs = function() {
            const isNew = document.getElementById('set-new').checked;
            document.getElementById('set-select').style.display = isNew ? 'none' : 'block';
            document.getElementById('set-name-input').style.display = isNew ? 'block' : 'none';
            
            if (isNew) {
                document.getElementById('set-select').removeAttribute('required');
                document.getElementById('set-name-input').setAttribute('required', 'required');
            } else {
                document.getElementById('set-select').setAttribute('required', 'required');
                document.getElementById('set-name-input').removeAttribute('required');
            }
        }

        window.toggleEditionInputs = function() {
            const isNew = document.getElementById('edition-new').checked;
            document.getElementById('edition-select').disabled = isNew;
        }

        window.toggleSchedule = function() {
            const notDropping = document.getElementById('dropping-no').checked;
            const scheduleGroup = document.getElementById('scheduled-drop-group');
            
            if (notDropping) {
                scheduleGroup.classList.add('show');
            } else {
                scheduleGroup.classList.remove('show');
                document.getElementById('scheduled-drop').value = '';
            }
        }

        // Message function
        function showMessage(text, isError = false) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = text;
            messageDiv.classList.remove('error');
            if (isError) {
                messageDiv.classList.add('error');
            }
            messageDiv.classList.add('show');
            
            setTimeout(() => {
                messageDiv.classList.remove('show');
            }, 4000);
        }

        // Form submission handlers
        function handleCardSubmit(event) {
            event.preventDefault();
            
            var formData = new FormData();
            var cardId = document.getElementById('card-id').value;
            var cardName = document.getElementById('card-name').value;
            
            // Handle edition
            var edition = 1;
            if (document.getElementById('edition-new').checked) {
                edition = (editionsData[cardName] || 0) + 1;
            } else {
                edition = document.getElementById('edition-select').value;
            }
            
            // Get image (file or URL)
            var imageFile = document.getElementById('card-image').files[0];
            var imageUrl = document.getElementById('image-url').value;
            
            // Only require image if creating new card (not editing)
            if (!isEditMode && !imageFile && !imageUrl) {
                showMessage('Please provide an image (file upload or URL)', true);
                return;
            }
            
            formData.append('card_id', cardId);
            formData.append('name', cardName);
            formData.append('edition', edition);
            formData.append('set_id', document.getElementById('set-existing').checked ? 
                document.getElementById('set-select').value : '');
            formData.append('set_name', document.getElementById('set-new').checked ? 
                document.getElementById('set-name-input').value : '');
            formData.append('cropMode', document.getElementById('crop-mode').value);
            formData.append('dropping', document.querySelector('input[name="dropping"]:checked').value);
            formData.append('scheduled_drop', document.getElementById('scheduled-drop').value || '');
            
            if (imageFile) {
                formData.append('image', imageFile);
            } else if (imageUrl) {
                formData.append('imageUrl', imageUrl);
            }
            
            // In edit mode without new image, skip preview and submit directly
            if (isEditMode && !imageFile && !imageUrl) {
                submitCardWithoutPreview(formData);
                return;
            }
            
            // Get the preview image and show confirmation
            var previewImg = document.getElementById('preview-image');
            if (previewImg && previewImg.src && previewImg.style.display !== 'none') {
                showCardConfirmation(previewImg.src, formData);
            } else {
                // If no preview available, generate one first
                showMessage('Generating preview...', false);
                updatePreviewThenConfirm(formData);
            }
        }

        function submitCardWithoutPreview(formData) {
            var cardId = formData.get('card_id');
            var url = '/admin/cards/' + cardId + '/update-info';
            
            fetch(url, {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    closeModal('card-modal');
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Operation failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred. Please try again.', true);
            });
        }

        function updatePreviewThenConfirm(formData) {
            // Generate preview first, then show confirmation
            var cardName = formData.get('name') || 'Card Name';
            var edition = formData.get('edition') || '1';
            var setName = formData.get('set_name') || 'Set Name';
            
            if (!setName || setName === 'Set Name') {
                var setSelect = document.getElementById('set-select');
                setName = setSelect.options[setSelect.selectedIndex]?.text || 'Set Name';
            }
            
            var previewFormData = new FormData();
            if (formData.get('image')) {
                previewFormData.append('image', formData.get('image'));
            } else {
                previewFormData.append('imageUrl', formData.get('imageUrl'));
            }
            previewFormData.append('name', cardName);
            previewFormData.append('subtitle', 'Edition ' + edition);
            previewFormData.append('footer', setName);
            previewFormData.append('cropMode', formData.get('cropMode'));
            
            fetch('/admin/cards/preview', {
                method: 'POST',
                body: previewFormData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    showCardConfirmation(data.preview, formData);
                } else {
                    showMessage('Failed to generate preview. Continue anyway?', false);
                    // Show confirmation without preview
                    showCardConfirmation('', formData);
                }
            })
            .catch(function(error) {
                showMessage('Preview generation error. Continue anyway?', false);
                showCardConfirmation('', formData);
            });
        }

        function handleStatsSubmit(event) {
            event.preventDefault();
            
            var cardId = document.getElementById('stats-card-id').value;
            var dropped = document.getElementById('dropped-count').value;
            var grabbed = document.getElementById('grabbed-count').value;
            
            fetch('/admin/cards/' + cardId + '/update-stats', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ dropped: dropped, grabbed: grabbed })
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage('Stats updated successfully');
                    closeModal('stats-modal');
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Update failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred. Please try again.', true);
            });
        }

        // Delete functions
        function deleteCard(cardId) {
            if (!confirm('Are you sure you want to DELETE this card? This action cannot be undone!')) {
                return;
            }
            
            fetch('/admin/cards/' + cardId + '/delete', {
                method: 'POST'
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Delete failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred. Please try again.', true);
            });
        }

        function deleteCopies(cardId) {
            if (!confirm('Are you sure you want to delete ALL owned copies of this card? This will remove them from all users!')) {
                return;
            }
            
            fetch('/admin/cards/' + cardId + '/delete-copies', {
                method: 'POST'
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                } else {
                    showMessage(result.error || 'Delete failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred. Please try again.', true);
            });
        }

        // Filter and Search Functions
        function filterCards() {
            var searchTerm = document.getElementById('search-input').value.toLowerCase();
            var sortBy = document.getElementById('sort-select').value;
            var statusFilter = document.getElementById('status-filter').value;
            
            var cardsGrid = document.querySelector('.cards-grid');
            var cardItems = Array.from(document.querySelectorAll('.card-item'));
            
            // Filter cards
            cardItems.forEach(function(card) {
                var cardName = card.getAttribute('data-name');
                var dropping = card.getAttribute('data-dropping');
                var scheduled = card.getAttribute('data-scheduled');
                
                var matchesSearch = cardName.includes(searchTerm);
                var matchesStatus = true;
                
                if (statusFilter === 'dropping') {
                    matchesStatus = dropping === '1';
                } else if (statusFilter === 'not-dropping') {
                    matchesStatus = dropping === '0' && scheduled === '0';
                } else if (statusFilter === 'scheduled') {
                    matchesStatus = scheduled === '1';
                }
                
                if (matchesSearch && matchesStatus) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
            
            // Sort cards
            var visibleCards = cardItems.filter(function(card) {
                return !card.classList.contains('hidden');
            });
            
            visibleCards.sort(function(a, b) {
                if (sortBy === 'id-asc') {
                    return parseInt(a.getAttribute('data-id')) - parseInt(b.getAttribute('data-id'));
                } else if (sortBy === 'id-desc') {
                    return parseInt(b.getAttribute('data-id')) - parseInt(a.getAttribute('data-id'));
                } else if (sortBy === 'name-asc') {
                    return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
                } else if (sortBy === 'name-desc') {
                    return b.getAttribute('data-name').localeCompare(a.getAttribute('data-name'));
                }
                return 0;
            });
            
            // Reorder in DOM
            visibleCards.forEach(function(card) {
                cardsGrid.appendChild(card);
            });
            
            // Show hidden cards at the end
            cardItems.filter(function(card) {
                return card.classList.contains('hidden');
            }).forEach(function(card) {
                cardsGrid.appendChild(card);
            });
        }

        function resetFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('sort-select').value = 'id-asc';
            document.getElementById('status-filter').value = 'all';
            filterCards();
        }

        // Update edition dropdown when card name changes
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('card-name').addEventListener('input', function() {
                var cardName = this.value;
                var maxEdition = editionsData[cardName] || 0;
                var select = document.getElementById('edition-select');
                
                select.innerHTML = '';
                for (var i = 1; i <= Math.max(maxEdition, 1); i++) {
                    var option = document.createElement('option');
                    option.value = i;
                    option.textContent = 'Edition ' + i;
                    select.appendChild(option);
                }
            });
        });

        // Bulk delete cards
        function bulkDeleteCards() {
            const checkboxes = document.querySelectorAll('.card-checkbox:checked');
            const ids = Array.from(checkboxes).map(cb => parseInt(cb.value));
            
            if (ids.length === 0) {
                alert('Please select cards to delete');
                return;
            }
            
            if (!confirm(`Delete ${ids.length} card(s)? This will also delete all owned copies. This cannot be undone!`)) {
                return;
            }
            
            fetch('/admin/cards/bulk-delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ids })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showMessage(data.message);
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showMessage(data.error || 'Failed to delete cards', true);
                }
            })
            .catch(err => {
                console.error('Bulk delete error:', err);
                showMessage('Failed to delete cards', true);
            });
        }

        // Reset economy
        function resetEconomy() {
            const confirmation = prompt('⚠️ WARNING: This will DELETE ALL CARDS and ALL OWNED CARDS!\\n\\nType "RESET ECONOMY" to confirm (case sensitive):');
            
            if (confirmation !== 'RESET ECONOMY') {
                alert('Reset cancelled - incorrect confirmation text');
                return;
            }
            
            const doubleCheck = confirm('Are you ABSOLUTELY SURE? This action CANNOT be undone!\\n\\nAll card data and ownership will be permanently lost.');
            
            if (!doubleCheck) {
                alert('Reset cancelled');
                return;
            }
            
            fetch('/admin/reset-economy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('✅ ' + data.message);
                    location.reload();
                } else {
                    alert('❌ Error: ' + data.error);
                }
            })
            .catch(err => {
                console.error('Reset economy error:', err);
                alert('❌ Failed to reset economy');
            });
        }
    </script>
</body>
</html>
