    <!-- Card Confirmation Modal -->
    <div id="confirm-modal" class="modal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal('confirm-modal')">&times;</button>
            <h3 class="modal-header">Confirm Card Creation</h3>
            
