    <!-- Bulk Preview Modal - NEW -->
    <div id="bulk-preview-modal" class="modal">
        <div class="modal-content" style="max-width: 1200px;">
            <button class="close-modal" onclick="closeModal('bulk-preview-modal')">&times;</button>
            <h3 class="modal-header">Preview Bulk Cards</h3>
            
