<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Management - Discord Cards</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #ff006e;
            --secondary: #8338ec;
            --accent: #00f5ff;
            --dark: #0a0e27;
            --card-bg: rgba(15, 23, 42, 0.6);
            --success: #00ff88;
            --warning: #ffaa00;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--dark);
            color: #fff;
            min-height: 100vh;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(255, 0, 110, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(131, 56, 236, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .navbar {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(131, 56, 236, 0.3);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            z-index: 100;
        }

        .navbar h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--secondary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .btn {
            padding: 10px 24px;
            background: transparent;
            border: 2px solid var(--secondary);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: var(--secondary);
            box-shadow: 0 0 20px rgba(131, 56, 236, 0.4);
            transform: translateY(-2px);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-color: var(--primary);
        }

        .btn-primary:hover {
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.4);
        }

        .btn-small {
            padding: 8px 16px;
            font-size: 0.9rem;
        }

        .btn-danger {
            border-color: var(--primary);
        }

        .btn-danger:hover {
            background: var(--primary);
        }

        .btn-warning {
            border-color: var(--warning);
        }

        .btn-warning:hover {
            background: var(--warning);
        }

        .btn-success {
            border-color: var(--success);
        }

        .btn-success:hover {
            background: var(--success);
            color: var(--dark);
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 40px 20px;
            position: relative;
            z-index: 10;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-header h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .message {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--success);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            color: var(--success);
            display: none;
            animation: slideDown 0.3s ease-out;
        }

        .message.show {
            display: block;
        }

        .message.error {
            border-color: var(--primary);
            color: var(--primary);
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .card-item {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            padding: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .card-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
        }

        .card-item:hover {
            transform: translateY(-5px);
            border-color: var(--secondary);
            box-shadow: 0 10px 30px rgba(131, 56, 236, 0.3);
        }

        .card-name {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.3rem;
            font-weight: 900;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .card-info {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
            margin-bottom: 5px;
        }

        .card-info strong {
            color: var(--accent);
        }

        .card-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        .status-dropping {
            background: rgba(0, 255, 136, 0.2);
            color: var(--success);
            border: 1px solid var(--success);
        }

        .status-scheduled {
            background: rgba(255, 170, 0, 0.2);
            color: var(--warning);
            border: 1px solid var(--warning);
        }

        .status-disabled {
            background: rgba(255, 0, 110, 0.2);
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .card-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 15px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 20px;
            overflow-y: auto;
        }

        .modal.show {
            display: flex;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 20px;
            padding: 40px;
            max-width: 600px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-header {
            font-family: 'Orbitron', sans-serif;
            font-size: 2rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 30px;
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 20px;
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            font-size: 2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .close-modal:hover {
            color: var(--primary);
            transform: rotate(90deg);
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: var(--accent);
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input, select, textarea {
            width: 100%;
            padding: 12px 16px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 15px rgba(255, 0, 110, 0.3);
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .checkbox-group input[type="checkbox"] {
            width: auto;
        }

        .checkbox-group label {
            margin: 0;
            text-transform: none;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        .form-actions .btn {
            flex: 1;
        }

        .no-cards {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 1.2rem;
        }

        .controls-panel {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 20px;
            align-items: end;
        }

        .search-box {
            display: flex;
            flex-direction: column;
        }

        .search-box input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 15px rgba(0, 245, 255, 0.3);
        }

        .filter-group {
            display: flex;
            flex-direction: column;
        }

        .filter-group label {
            color: var(--accent);
            font-weight: 700;
            font-size: 0.85rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .filter-group select {
            padding: 12px 16px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-group select:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 15px rgba(131, 56, 236, 0.3);
        }

        .card-item.hidden {
            display: none;
        }

        @media (max-width: 1024px) {
            .controls-panel {
                grid-template-columns: 1fr;
            }
        }

        .no-cards {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 1.2rem;
        }

        .edition-input-group {
            display: flex;
            gap: 10px;
            align-items: flex-end;
        }

        .edition-input-group > div {
            flex: 1;
        }

        .edition-input-group input[type="radio"] {
            width: auto;
            margin-right: 5px;
        }

        .radio-option {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
            cursor: pointer;
        }

        .radio-option label {
            margin: 0;
            cursor: pointer;
            text-transform: none;
        }

        #scheduled-drop-group {
            display: none;
            margin-top: 15px;
        }

        #scheduled-drop-group.show {
            display: block;
        }

        .card-image {
            width: 100%;
            height: 200px;
            object-fit: contain;
            background: rgba(10, 14, 39, 0.6);
            border-radius: 10px;
            margin-bottom: 15px;
            border: 2px solid rgba(131, 56, 236, 0.3);
        }

        .preview-container {
            margin-top: 20px;
            text-align: center;
        }

        .preview-image {
            max-width: 100%;
            max-height: 400px;
            border-radius: 10px;
            border: 2px solid var(--secondary);
            background: rgba(10, 14, 39, 0.8);
        }

        .preview-loading {
            color: var(--accent);
            font-style: italic;
        }

        .hidden {
            display: none !important;
        }

        .bulk-card-item {
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .bulk-card-item input {
            margin-bottom: 10px;
        }

        .bulk-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .controls-panel {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 30px;
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 200px;
        }

        .search-box input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .filter-group label {
            font-size: 0.85rem;
            color: var(--accent);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .filter-group select {
            padding: 10px 14px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <h1>CARD MANAGEMENT</h1>
        <div class="navbar-right">
            <a href="/admin" class="btn">User Management</a>
            <a href="/dashboard" class="btn">Dashboard</a>
            <a href="/logout" class="btn">Logout</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h2>Manage Cards</h2>
            <div style="display: flex; gap: 10px;">
                <button class="btn" onclick="location.reload()" title="Refresh page">
                    🔄 Refresh
                </button>
                <button class="btn btn-danger" onclick="bulkDeleteCards()" title="Delete selected cards">
                    🗑️ Delete Selected
                </button>
                <button class="btn" style="background: #dc3545; border-color: #dc3545;" onclick="resetEconomy()" title="WARNING: Deletes ALL cards and owned cards">
                    ⚠️ Reset Economy
                </button>
                <button class="btn btn-primary" onclick="openBulkModal()">+ Bulk Add Cards</button>
                <button class="btn btn-primary" onclick="openCreateModal()">+ Add New Card</button>
            </div>
        </div>

        <div id="message" class="message"></div>

        <!-- Search and Filter Controls -->
        <div class="controls-panel">
            <div class="search-box">
                <input type="text" id="search-input" placeholder="Search cards by name..." onkeyup="filterCards()">
            </div>
            
            <div class="filter-group">
                <label for="sort-select">Sort By:</label>
                <select id="sort-select" onchange="filterCards()">
                    <option value="id-asc">ID (Ascending)</option>
                    <option value="id-desc">ID (Descending)</option>
                    <option value="name-asc">Name (A-Z)</option>
                    <option value="name-desc">Name (Z-A)</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label for="status-filter">Status:</label>
                <select id="status-filter" onchange="filterCards()">
                    <option value="all">All Cards</option>
                    <option value="dropping">Dropping Only</option>
                    <option value="not-dropping">Not Dropping Only</option>
                    <option value="scheduled">Scheduled Only</option>
                </select>
            </div>
            
            <button class="btn btn-small" onclick="resetFilters()">Reset Filters</button>
        </div>

        <div class="cards-grid">
            <% if (cards.length === 0) { %>
                <div class="no-cards" style="grid-column: 1 / -1;">
                    No cards yet. Create your first card!
                </div>
            <% } else { %>
                <% cards.forEach(card => { %>
                    <div class="card-item" 
                         data-id="<%= card.id %>" 
                         data-name="<%= card.name.toLowerCase() %>"
                         data-dropping="<%= card.dropping %>"
                         data-scheduled="<%= card.scheduled_drop ? '1' : '0' %>">
                        <input type="checkbox" class="card-checkbox" value="<%= card.id %>" style="position: absolute; top: 10px; left: 10px; width: 20px; height: 20px; cursor: pointer; z-index: 10;">
                        <% if (card.bordered_image) { %>
                            <img src="/cards/images/<%= card.bordered_image %>" alt="<%= card.name %>" class="card-image">
                        <% } %>
                        <div class="card-name"><%= card.name %></div>
                        <div class="card-info"><strong>ID:</strong> <%= card.id %></div>
                        <div class="card-info"><strong>Edition:</strong> <%= card.edition %></div>
                        <div class="card-info"><strong>Set:</strong> <%= card.set_name %></div>
                        <div class="card-info"><strong>Dropped:</strong> <%= card.dropped %></div>
                        <div class="card-info"><strong>Grabbed:</strong> <%= card.grabbed %></div>
                        
                        <% if (card.dropping === 1) { %>
                            <span class="card-status status-dropping">Dropping</span>
                        <% } else if (card.scheduled_drop) { %>
                            <span class="card-status status-scheduled">Scheduled</span>
                        <% } else { %>
                            <span class="card-status status-disabled">Not Dropping</span>
                        <% } %>

                        <div class="card-actions">
                            <button class="btn btn-small" onclick="openEditModal(<%= card.id %>)">Edit Info</button>
                            <button class="btn btn-small btn-warning" onclick="openStatsModal(<%= card.id %>, <%= card.dropped %>, <%= card.grabbed %>)">Edit Stats</button>
                            <button class="btn btn-small btn-danger" onclick="deleteCard(<%= card.id %>)">Delete Card</button>
                            <button class="btn btn-small btn-danger" onclick="deleteCopies(<%= card.id %>)">Delete Copies</button>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <!-- Create/Edit Card Modal -->
    <div id="card-modal" class="modal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal('card-modal')">&times;</button>
            <h3 class="modal-header" id="modal-title">Add New Card</h3>
            <form id="card-form" onsubmit="handleCardSubmit(event)">
                <input type="hidden" id="card-id" name="card_id">
                
                <div class="form-group">
                    <label for="card-name">Card Name</label>
                    <input type="text" id="card-name" name="name" required onchange="updatePreview()" oninput="updatePreview()">
                </div>

                <div class="form-group">
                    <label>Edition</label>
                    <div class="radio-option">
                        <input type="radio" id="edition-existing" name="edition-type" value="existing" checked onchange="toggleEditionInputs()">
                        <label for="edition-existing">Use Existing Edition</label>
                    </div>
                    <select id="edition-select" name="edition">
                        <option value="1">Edition 1 (Default)</option>
                    </select>
                    
                    <div class="radio-option" style="margin-top: 10px;">
                        <input type="radio" id="edition-new" name="edition-type" value="new" onchange="toggleEditionInputs()">
                        <label for="edition-new">Create New Edition (Highest + 1)</label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Set</label>
                    <div class="radio-option">
                        <input type="radio" id="set-existing" name="set-type" value="existing" checked onchange="toggleSetInputs()">
                        <label for="set-existing">Use Existing Set</label>
                    </div>
                    <select id="set-select" name="set_id" onchange="updatePreview()">
                        <% if (sets.length === 0) { %>
                            <option value="">No sets available - create one below</option>
                        <% } else { %>
                            <% sets.forEach(set => { %>
                                <option value="<%= set.id %>"><%= set.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                    
                    <div class="radio-option" style="margin-top: 10px;">
                        <input type="radio" id="set-new" name="set-type" value="new" onchange="toggleSetInputs()">
                        <label for="set-new">Create New Set</label>
                    </div>
                    <input type="text" id="set-name-input" name="set_name" placeholder="New set name" style="display: none; margin-top: 10px;" onchange="updatePreview()" oninput="updatePreview()">
                </div>

                <div class="form-group">
                    <label for="card-image">Card Image</label>
                    <input type="file" id="card-image" accept="image/*" onchange="handleImageChange()">
                    <input type="text" id="image-url" name="image_url" placeholder="Or paste image URL" style="margin-top: 10px;" onchange="handleImageChange()">
                </div>

                <div class="form-group">
                    <label for="crop-mode">Crop Mode</label>
                    <select id="crop-mode" name="cropMode" onchange="updatePreview()">
                        <option value="centre">Center (Default)</option>
                        <option value="top">Top</option>
                        <option value="bottom">Bottom</option>
                        <option value="left">Left</option>
                        <option value="right">Right</option>
                        <option value="stretch">Stretch</option>
                    </select>
                </div>

                <div class="preview-container" id="preview-container" style="display: none;">
                    <label>Card Preview</label>
                    <div id="preview-loading" class="preview-loading" style="display: none;">Generating preview...</div>
                    <img id="preview-image" class="preview-image" style="display: none;">
                </div>

                <div class="form-group">
                    <label>Dropping Status</label>
                    <div class="radio-option">
                        <input type="radio" id="dropping-yes" name="dropping" value="1" checked onchange="toggleSchedule()">
                        <label for="dropping-yes">Yes - Drop immediately</label>
                    </div>
                    <div class="radio-option">
                        <input type="radio" id="dropping-no" name="dropping" value="0" onchange="toggleSchedule()">
                        <label for="dropping-no">No - Don't drop yet</label>
                    </div>
                </div>

                <div id="scheduled-drop-group" class="form-group">
