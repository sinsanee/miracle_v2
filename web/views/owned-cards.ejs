<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owned Cards Management - Discord Cards</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #ff006e;
            --secondary: #8338ec;
            --accent: #00f5ff;
            --dark: #0a0e27;
            --card-bg: rgba(15, 23, 42, 0.6);
            --success: #00ff88;
            --warning: #ffaa00;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--dark);
            color: #fff;
            min-height: 100vh;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(255, 0, 110, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(131, 56, 236, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .navbar {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(131, 56, 236, 0.3);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            z-index: 100;
        }

        .navbar h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--secondary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .btn {
            padding: 10px 24px;
            background: transparent;
            border: 2px solid var(--secondary);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: var(--secondary);
            box-shadow: 0 0 20px rgba(131, 56, 236, 0.4);
            transform: translateY(-2px);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-color: var(--primary);
        }

        .btn-small {
            padding: 8px 16px;
            font-size: 0.9rem;
        }

        .btn-danger {
            border-color: var(--primary);
        }

        .btn-danger:hover {
            background: var(--primary);
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 40px 20px;
            position: relative;
            z-index: 10;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-header h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .message {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--success);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            color: var(--success);
            display: none;
        }

        .message.show {
            display: block;
        }

        .message.error {
            border-color: var(--primary);
            color: var(--primary);
        }

        .controls {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .controls-row {
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .control-group {
            flex: 1;
            min-width: 200px;
        }

        .control-group label {
            display: block;
            margin-bottom: 5px;
            color: var(--accent);
            font-weight: 600;
        }

        .control-group input,
        .control-group select {
            width: 100%;
            padding: 10px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
        }

        table {
            width: 100%;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            overflow: hidden;
        }

        thead {
            background: rgba(131, 56, 236, 0.2);
        }

        th {
            padding: 15px;
            text-align: left;
            font-weight: 700;
            color: var(--accent);
            border-bottom: 1px solid rgba(131, 56, 236, 0.3);
        }

        td {
            padding: 15px;
            border-bottom: 1px solid rgba(131, 56, 236, 0.1);
        }

        tr:hover {
            background: rgba(131, 56, 236, 0.1);
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal.show {
            display: flex;
        }

        .modal-content {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.5);
            border-radius: 20px;
            padding: 40px;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .modal-header h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            color: var(--accent);
        }

        .close-btn {
            background: none;
            border: none;
            color: var(--primary);
            font-size: 2rem;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--accent);
            font-weight: 600;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <h1>OWNED CARDS</h1>
        <div class="navbar-right">
            <a href="/dashboard" class="btn">Dashboard</a>
            <a href="/admin/cards" class="btn">Cards</a>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>
    </div>

    <div class="container">
        <div class="page-header">
            <h2>Manage Owned Cards</h2>
            <button class="btn btn-primary" onclick="openModal('generate-modal')">Generate Card</button>
        </div>

        <div id="message" class="message"></div>

        <div class="controls">
            <div class="controls-row">
                <div class="control-group">
                    <label>Search</label>
                    <input type="text" id="search-input" placeholder="Search by ID or card name..." oninput="filterOwnedCards()">
                </div>
                <div class="control-group">
                    <label>Sort By</label>
                    <select id="sort-select" onchange="filterOwnedCards()">
                        <option value="id-desc">ID (Newest First)</option>
                        <option value="id-asc">ID (Oldest First)</option>
                        <option value="print-asc">Print # (Low to High)</option>
                        <option value="print-desc">Print # (High to Low)</option>
                        <option value="name-asc">Card Name (A-Z)</option>
                        <option value="name-desc">Card Name (Z-A)</option>
                        <option value="owner-asc">Owner (A-Z)</option>
                        <option value="owner-desc">Owner (Z-A)</option>
                    </select>
                </div>
                <div class="control-group">
                    <button class="btn" onclick="resetFilters()" style="margin-top: 25px;">Reset Filters</button>
                </div>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Card Name</th>
                    <th>Print #</th>
                    <th>Edition</th>
                    <th>Dropper</th>
                    <th>Grabber</th>
                    <th>Owner</th>
                    <th>Condition</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% ownedCards.forEach(function(card) { %>
                <tr class="owned-card-row"
                    data-id="<%= card.id %>"
                    data-name="<%= (card.card_name || '').toLowerCase() %>"
                    data-print="<%= card.print %>"
                    data-owner="<%= (card.owner || '').toLowerCase() %>">
                    <td><strong><%= card.id %></strong></td>
                    <td><%= card.card_name || 'Unknown' %></td>
                    <td>#<%= card.print %></td>
                    <td>E<%= card.edition %></td>
                    <td><%= card.dropper || '-' %></td>
                    <td><%= card.grabber || '-' %></td>
                    <td><%= card.owner || '-' %></td>
                    <td><%= ['', 'Poor', 'Played', 'Good', 'Near Mint', 'Mint'][card.condition] || card.condition %></td>
                    <td>
                        <button class="btn btn-small" onclick='editOwnedCard("<%= card.id %>", "<%= card.card %>", "<%= card.print %>", "<%= card.dropper || "" %>", "<%= card.grabber || "" %>", "<%= card.owner || "" %>", <%= card.condition %>)'>Edit</button>
                        <button class="btn btn-small btn-danger" onclick='deleteOwnedCard("<%= card.id %>")'>Delete</button>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Generate Modal -->
    <div id="generate-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Generate Owned Card</h3>
                <button class="close-btn" onclick="closeModal('generate-modal')">&times;</button>
            </div>
            <form onsubmit="handleGenerate(event)">
                <div class="form-group">
                    <label>Card *</label>
                    <input type="text" id="gen-card-search" placeholder="Search for a card..." oninput="searchCardsForGen(this.value)" autocomplete="off">
                    <div id="gen-card-results" style="max-height: 200px; overflow-y: auto; border: 1px solid rgba(131, 56, 236, 0.3); border-radius: 8px; margin-top: 5px; display: none; background: rgba(10, 14, 39, 0.9);"></div>
                    <input type="hidden" id="gen-card-id" required>
                    <div id="gen-selected-card" style="margin-top: 10px; padding: 10px; background: rgba(131, 56, 236, 0.2); border-radius: 8px; display: none;"></div>
                </div>
                <div class="form-group">
                    <label>Owner (Discord User ID)</label>
                    <input type="text" id="gen-owner" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Dropper (Discord User ID)</label>
                    <input type="text" id="gen-dropper" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Grabber (Discord User ID)</label>
                    <input type="text" id="gen-grabber" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Condition</label>
                    <select id="gen-condition" required>
                        <option value="1">Poor</option>
                        <option value="2">Played</option>
                        <option value="3">Good</option>
                        <option value="4">Near Mint</option>
                        <option value="5" selected>Mint</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Generate</button>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Edit Owned Card</h3>
                <button class="close-btn" onclick="closeModal('edit-modal')">&times;</button>
            </div>
            <form onsubmit="handleUpdate(event)">
                <input type="hidden" id="edit-id">
                <div class="form-group">
                    <label>Card ID (Cannot be changed)</label>
                    <input type="text" id="edit-card-id" disabled>
                </div>
                <div class="form-group">
                    <label>Print # (Cannot be changed)</label>
                    <input type="text" id="edit-print" disabled>
                </div>
                <div class="form-group">
                    <label>Owner (Discord User ID)</label>
                    <input type="text" id="edit-owner" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Dropper (Discord User ID)</label>
                    <input type="text" id="edit-dropper" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Grabber (Discord User ID)</label>
                    <input type="text" id="edit-grabber" placeholder="Optional">
                </div>
                <div class="form-group">
                    <label>Condition</label>
                    <select id="edit-condition" required>
                        <option value="1">Poor</option>
                        <option value="2">Played</option>
                        <option value="3">Good</option>
                        <option value="4">Near Mint</option>
                        <option value="5">Mint</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Update</button>
            </form>
        </div>
    </div>

    <script>
        function showMessage(text, isError) {
            var message = document.getElementById('message');
            message.textContent = text;
            message.className = 'message show' + (isError ? ' error' : '');
            setTimeout(function() {
                message.className = 'message';
            }, 5000);
        }

        function openModal(id) {
            document.getElementById(id).classList.add('show');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        function handleGenerate(event) {
            event.preventDefault();
            
            var formData = {
                card_id: document.getElementById('gen-card-id').value,
                owner: document.getElementById('gen-owner').value,
                dropper: document.getElementById('gen-dropper').value,
                grabber: document.getElementById('gen-grabber').value,
                condition: document.getElementById('gen-condition').value
            };

            fetch('/admin/owned-cards/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage('Card generated with ID: ' + result.id + ' (Print #' + result.print + ')');
                    closeModal('generate-modal');
                    setTimeout(function() { location.reload(); }, 1500);
                } else {
                    showMessage(result.error || 'Failed to generate card', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred', true);
            });
        }

        function editOwnedCard(id, cardId, print, dropper, grabber, owner, condition) {
            document.getElementById('edit-id').value = id;
            document.getElementById('edit-card-id').value = cardId;
            document.getElementById('edit-print').value = print;
            document.getElementById('edit-dropper').value = dropper;
            document.getElementById('edit-grabber').value = grabber;
            document.getElementById('edit-owner').value = owner;
            document.getElementById('edit-condition').value = condition;
            openModal('edit-modal');
        }

        function handleUpdate(event) {
            event.preventDefault();
            
            var id = document.getElementById('edit-id').value;
            var formData = {
                dropper: document.getElementById('edit-dropper').value,
                grabber: document.getElementById('edit-grabber').value,
                owner: document.getElementById('edit-owner').value,
                condition: document.getElementById('edit-condition').value
            };

            fetch('/admin/owned-cards/' + id + '/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    closeModal('edit-modal');
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Update failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred', true);
            });
        }

        function deleteOwnedCard(id) {
            if (!confirm('Are you sure you want to delete this owned card?')) {
                return;
            }

            fetch('/admin/owned-cards/' + id + '/delete', {
                method: 'POST'
            })
            .then(function(response) { return response.json(); })
            .then(function(result) {
                if (result.success) {
                    showMessage(result.message);
                    setTimeout(function() { location.reload(); }, 1000);
                } else {
                    showMessage(result.error || 'Delete failed', true);
                }
            })
            .catch(function(error) {
                showMessage('An error occurred', true);
            });
        }

        function filterOwnedCards() {
            var searchTerm = document.getElementById('search-input').value.toLowerCase();
            var sortBy = document.getElementById('sort-select').value;
            
            var tbody = document.querySelector('tbody');
            var rows = Array.from(document.querySelectorAll('.owned-card-row'));
            
            // Filter rows
            rows.forEach(function(row) {
                var id = row.getAttribute('data-id').toLowerCase();
                var name = row.getAttribute('data-name');
                
                var matchesSearch = id.includes(searchTerm) || name.includes(searchTerm);
                
                if (matchesSearch) {
                    row.classList.remove('hidden');
                } else {
                    row.classList.add('hidden');
                }
            });
            
            // Sort visible rows
            var visibleRows = rows.filter(function(row) {
                return !row.classList.contains('hidden');
            });
            
            visibleRows.sort(function(a, b) {
                if (sortBy === 'id-asc') {
                    return a.getAttribute('data-id').localeCompare(b.getAttribute('data-id'));
                } else if (sortBy === 'id-desc') {
                    return b.getAttribute('data-id').localeCompare(a.getAttribute('data-id'));
                } else if (sortBy === 'print-asc') {
                    return parseInt(a.getAttribute('data-print')) - parseInt(b.getAttribute('data-print'));
                } else if (sortBy === 'print-desc') {
                    return parseInt(b.getAttribute('data-print')) - parseInt(a.getAttribute('data-print'));
                } else if (sortBy === 'name-asc') {
                    return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
                } else if (sortBy === 'name-desc') {
                    return b.getAttribute('data-name').localeCompare(a.getAttribute('data-name'));
                } else if (sortBy === 'owner-asc') {
                    return a.getAttribute('data-owner').localeCompare(b.getAttribute('data-owner'));
                } else if (sortBy === 'owner-desc') {
                    return b.getAttribute('data-owner').localeCompare(a.getAttribute('data-owner'));
                }
                return 0;
            });
            
            // Reorder in DOM
            visibleRows.forEach(function(row) {
                tbody.appendChild(row);
            });
            
            // Show hidden rows at the end
            rows.filter(function(row) {
                return row.classList.contains('hidden');
            }).forEach(function(row) {
                tbody.appendChild(row);
            });
        }

        function resetFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('sort-select').value = 'id-desc';
            filterOwnedCards();
        }

        // Card search for owned card generation
        var allCards = <%- JSON.stringify(cards || []) %>;
        
        console.log('All cards loaded:', allCards.length, allCards);
        
        function searchCardsForGen(query) {
            var resultsContainer = document.getElementById('gen-card-results');
            var selectedCard = document.getElementById('gen-selected-card');
            
            console.log('Searching for:', query, 'Total cards:', allCards.length);
            
            if (!allCards || allCards.length === 0) {
                resultsContainer.innerHTML = '<div style="padding: 10px; color: rgba(255,255,255,0.5);">No cards available</div>';
                resultsContainer.style.display = 'block';
                return;
            }
            
            if (!query || query.length < 2) {
                resultsContainer.style.display = 'none';
                return;
            }
            
            var filtered = allCards.filter(function(card) {
                var searchText = (card.name + ' ' + card.edition + ' ' + (card.set_name || '')).toLowerCase();
                return searchText.includes(query.toLowerCase());
            });
            
            console.log('Filtered results:', filtered.length, filtered);
            
            if (filtered.length === 0) {
                resultsContainer.innerHTML = '<div style="padding: 10px; color: rgba(255,255,255,0.5);">No cards found</div>';
                resultsContainer.style.display = 'block';
                return;
            }
            
            resultsContainer.innerHTML = '';
            filtered.slice(0, 10).forEach(function(card) {
                var item = document.createElement('div');
                item.style.cssText = 'padding: 10px; cursor: pointer; border-bottom: 1px solid rgba(131, 56, 236, 0.2);';
                var setInfo = card.set_name ? ' (' + card.set_name + ')' : '';
                item.innerHTML = '<strong>' + card.name + '</strong> - Edition ' + card.edition + setInfo;
                item.onmouseover = function() { this.style.background = 'rgba(131, 56, 236, 0.3)'; };
                item.onmouseout = function() { this.style.background = 'transparent'; };
                item.onclick = function() {
                    document.getElementById('gen-card-id').value = card.id;
                    document.getElementById('gen-card-search').value = '';
                    var selectedSetInfo = card.set_name ? ' (' + card.set_name + ')' : '';
                    selectedCard.innerHTML = '<strong>Selected:</strong> ' + card.name + ' - Edition ' + card.edition + selectedSetInfo;
                    selectedCard.style.display = 'block';
                    resultsContainer.style.display = 'none';
                };
                resultsContainer.appendChild(item);
            });
            
            resultsContainer.style.display = 'block';
        }
    </script>
</body>
</html>
