<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sets Management - Discord Cards</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #ff006e;
            --secondary: #8338ec;
            --accent: #00f5ff;
            --dark: #0a0e27;
            --card-bg: rgba(15, 23, 42, 0.6);
            --success: #00ff88;
            --warning: #ffaa00;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--dark);
            color: #fff;
            min-height: 100vh;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background:
                radial-gradient(circle at 20% 50%, rgba(255, 0, 110, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(131, 56, 236, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .navbar {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(131, 56, 236, 0.3);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            z-index: 100;
        }

        .navbar h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--secondary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-right { display: flex; align-items: center; gap: 20px; }

        .btn {
            padding: 10px 24px;
            background: transparent;
            border: 2px solid var(--secondary);
            border-radius: 8px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn:hover {
            background: var(--secondary);
            box-shadow: 0 0 20px rgba(131, 56, 236, 0.4);
            transform: translateY(-2px);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-color: var(--primary);
        }

        .btn-primary:hover { box-shadow: 0 0 20px rgba(255, 0, 110, 0.4); }

        .btn-small { padding: 8px 16px; font-size: 0.9rem; }

        .btn-danger { border-color: var(--primary); }
        .btn-danger:hover { background: var(--primary); }

        .btn-warning { border-color: var(--warning); }
        .btn-warning:hover { background: var(--warning); color: var(--dark); }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
            position: relative;
            z-index: 10;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .page-header h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .message {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--success);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
            color: var(--success);
            display: none;
            animation: slideDown 0.3s ease-out;
        }

        .message.show { display: block; }
        .message.error { border-color: var(--primary); color: var(--primary); }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .sets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .set-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 15px;
            padding: 20px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .set-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
        }

        .set-card:hover {
            transform: translateY(-5px);
            border-color: var(--secondary);
            box-shadow: 0 10px 30px rgba(131, 56, 236, 0.3);
        }

        .set-name {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2rem;
            font-weight: 900;
            color: var(--accent);
            margin-bottom: 12px;
        }

        .set-info {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
            margin-bottom: 6px;
        }

        .set-info strong { color: var(--accent); }

        .border-preview {
            width: 100%;
            max-height: 120px;
            object-fit: contain;
            border-radius: 8px;
            border: 1px solid rgba(131, 56, 236, 0.3);
            margin-bottom: 14px;
            background: rgba(10, 14, 39, 0.6);
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
        }

        .status-available {
            background: rgba(0, 255, 136, 0.2);
            color: var(--success);
            border: 1px solid var(--success);
        }

        .status-unavailable {
            background: rgba(255, 0, 110, 0.2);
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .set-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 15px;
        }

        .no-sets {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 1.2rem;
            grid-column: 1 / -1;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            z-index: 1000;
            padding: 20px;
            overflow-y: auto;
        }

        .modal.show {
            display: flex;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .modal-content {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(131, 56, 236, 0.3);
            border-radius: 20px;
            padding: 40px;
            max-width: 560px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .modal-header {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 30px;
        }

        .close-modal {
            position: absolute;
            top: 20px; right: 20px;
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            font-size: 2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .close-modal:hover { color: var(--primary); transform: rotate(90deg); }

        .form-group { margin-bottom: 20px; }

        label {
            display: block;
            color: var(--accent);
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input[type="text"],
        input[type="number"],
        select {
            width: 100%;
            padding: 12px 16px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px solid rgba(131, 56, 236, 0.3);
            border-radius: 10px;
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        input[type="file"] {
            width: 100%;
            padding: 10px;
            background: rgba(10, 14, 39, 0.6);
            border: 2px dashed rgba(131, 56, 236, 0.5);
            border-radius: 10px;
            color: rgba(255,255,255,0.7);
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.95rem;
            cursor: pointer;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 15px rgba(255, 0, 110, 0.3);
        }

        .form-actions {
            display: flex;
            gap: 10px;
            margin-top: 30px;
        }

        .form-actions .btn { flex: 1; }

        .current-border-preview {
            width: 100%;
            max-height: 80px;
            object-fit: contain;
            border-radius: 6px;
            border: 1px solid rgba(131, 56, 236, 0.3);
            margin-bottom: 8px;
            display: none;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <h1>SETS MANAGEMENT</h1>
        <div class="navbar-right">
            <a href="/admin/cards" class="btn">Cards</a>
            <a href="/dashboard" class="btn">Dashboard</a>
            <a href="/logout" class="btn">Logout</a>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h2>Manage Sets</h2>
            <div style="display: flex; gap: 10px;">
                <button class="btn" onclick="refreshSets()" title="Refresh">🔄 Refresh</button>
                <button class="btn btn-primary" onclick="openCreateModal()">+ Add New Set</button>
            </div>
        </div>

        <div id="message" class="message"></div>

        <div class="sets-grid" id="sets-grid">
            <% if (sets.length === 0) { %>
                <div class="no-sets">No sets yet. Create your first set!</div>
            <% } else { %>
                <% sets.forEach(function(set) { %>
                <div class="set-card" data-id="<%= set.id %>">
                    <% if (set.border) { %>
                        <img src="/img/borders/<%= set.border %>" alt="Border" class="border-preview" onerror="this.style.display='none'">
                    <% } %>
                    <div class="set-name"><%= set.name %></div>
                    <div class="set-info"><strong>ID:</strong> <%= set.id %></div>
                    <div class="set-info"><strong>Border:</strong> <%= set.border || '(none)' %></div>
                    <div class="set-info"><strong>Rarity:</strong> <%= set.rarity %></div>
                    <span class="status-badge <%= set.available == 1 ? 'status-available' : 'status-unavailable' %>">
                        <%= set.available == 1 ? 'Dropping' : 'Not Dropping' %>
                    </span>
                    <div class="set-actions">
                        <button class="btn btn-small btn-warning" onclick="openEditModal(<%= set.id %>, '<%= set.name.replace(/'/g, "\\'") %>', '<%= (set.border || '').replace(/'/g, "\\'") %>', <%= set.rarity %>, <%= set.available %>)">Edit</button>
                        <button class="btn btn-small btn-danger" onclick="deleteSet(<%= set.id %>)">Delete</button>
                    </div>
                </div>
                <% }); %>
            <% } %>
        </div>
    </div>

    <!-- Create Set Modal -->
    <div id="create-modal" class="modal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal('create-modal')">&times;</button>
            <h3 class="modal-header">Add New Set</h3>
            <form id="create-form" onsubmit="handleCreate(event)" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="create-name">Set Name</label>
                    <input type="text" id="create-name" name="name" required placeholder="e.g. Legends">
                </div>

                <div class="form-group">
                    <label for="create-border">Border Image</label>
                    <input type="file" id="create-border" name="border" accept="image/*">
                    <small style="color: rgba(255,255,255,0.5); margin-top: 4px; display: block;">Saved as &lt;filename&gt;.png in the borders folder</small>
                </div>

                <div class="form-group">
                    <label for="create-rarity">Rarity (number)</label>
                    <input type="number" id="create-rarity" name="rarity" value="100" min="1" required>
                </div>

                <div class="form-group">
                    <label for="create-available">Available (dropping?)</label>
                    <select id="create-available" name="available">
                        <option value="1">1 — Yes, dropping</option>
                        <option value="0" selected>0 — No, not dropping</option>
                    </select>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn" onclick="closeModal('create-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Set</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Set Modal -->
    <div id="edit-modal" class="modal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal('edit-modal')">&times;</button>
            <h3 class="modal-header">Edit Set</h3>
            <form id="edit-form" onsubmit="handleEdit(event)" enctype="multipart/form-data">
                <input type="hidden" id="edit-set-id">

                <div class="form-group">
                    <label for="edit-name">Set Name</label>
                    <input type="text" id="edit-name" name="name" required>
                </div>

                <div class="form-group">
                    <label>Current Border</label>
                    <img id="edit-current-border" class="current-border-preview" src="" alt="Current border">
                    <small id="edit-border-filename" style="color: rgba(255,255,255,0.5); display: block; margin-bottom: 8px;"></small>
                    <label for="edit-border">Replace Border Image (optional)</label>
                    <input type="file" id="edit-border" name="border" accept="image/*">
                </div>

                <div class="form-group">
                    <label for="edit-rarity">Rarity (number)</label>
                    <input type="number" id="edit-rarity" name="rarity" min="1" required>
                </div>

                <div class="form-group">
                    <label for="edit-available">Available (dropping?)</label>
                    <select id="edit-available" name="available">
                        <option value="1">1 — Yes, dropping</option>
                        <option value="0">0 — No, not dropping</option>
                    </select>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn" onclick="closeModal('edit-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showMessage(text, isError) {
            var msg = document.getElementById('message');
            msg.textContent = text;
            msg.className = 'message show' + (isError ? ' error' : '');
            setTimeout(function() { msg.className = 'message'; }, 4000);
        }

        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }

        function openCreateModal() {
            document.getElementById('create-form').reset();
            openModal('create-modal');
        }

        function openEditModal(id, name, border, rarity, available) {
            document.getElementById('edit-set-id').value = id;
            document.getElementById('edit-name').value = name;
            document.getElementById('edit-rarity').value = rarity;
            document.getElementById('edit-available').value = available;
            document.getElementById('edit-border').value = '';

            var previewImg = document.getElementById('edit-current-border');
            var filenameEl = document.getElementById('edit-border-filename');

            if (border) {
                previewImg.src = '/img/borders/' + border;
                previewImg.style.display = 'block';
                filenameEl.textContent = 'Current file: ' + border;
            } else {
                previewImg.style.display = 'none';
                filenameEl.textContent = 'No border set';
            }

            openModal('edit-modal');
        }

        function handleCreate(event) {
            event.preventDefault();
            var formData = new FormData(document.getElementById('create-form'));

            fetch('/admin/sets/create', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) {
                        showMessage(data.message);
                        closeModal('create-modal');
                        setTimeout(function() { location.reload(); }, 1200);
                    } else {
                        showMessage(data.error || 'Failed to create set', true);
                    }
                })
                .catch(function() { showMessage('An error occurred', true); });
        }

        function handleEdit(event) {
            event.preventDefault();
            var id = document.getElementById('edit-set-id').value;
            var formData = new FormData(document.getElementById('edit-form'));

            fetch('/admin/sets/' + id + '/update', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) {
                        showMessage(data.message);
                        closeModal('edit-modal');
                        setTimeout(function() { location.reload(); }, 1200);
                    } else {
                        showMessage(data.error || 'Failed to update set', true);
                    }
                })
                .catch(function() { showMessage('An error occurred', true); });
        }

        function deleteSet(id) {
            if (!confirm('Are you sure you want to delete this set? Cards linked to it will lose their set association.')) return;

            fetch('/admin/sets/' + id + '/delete', { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) {
                        showMessage(data.message);
                        setTimeout(function() { location.reload(); }, 1000);
                    } else {
                        showMessage(data.error || 'Delete failed', true);
                    }
                })
                .catch(function() { showMessage('An error occurred', true); });
        }

        function refreshSets() {
            location.reload();
        }
    </script>
</body>
</html>
